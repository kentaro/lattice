#!/bin/bash
# lattice — SuperCollider シンセ起動スクリプト
# Usage: bash bin/lattice

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SC_MAIN="$SCRIPT_DIR/../sc/main.scd"

# 既存プロセスを停止
pkill jackd 2>/dev/null || true
pkill sclang 2>/dev/null || true
sleep 1

# PulseAudio が hw:1 (HDMI) を占有しているので解放する
pulseaudio --kill 2>/dev/null || true
sleep 1

# jackd のデフォルトデバイスを HDMI に設定
echo "-d alsa -d hw:1 -r 44100 -p 1024 -n 2" > ~/.jackdrc

echo "[lattice] Starting SuperCollider (HDMI via JACK hw:1)..."
export QT_QPA_PLATFORM=offscreen
exec sclang "$SC_MAIN"
