#!/bin/bash
# lattice — SuperCollider シンセ起動スクリプト
# Usage: bash bin/lattice

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SC_MAIN="$SCRIPT_DIR/../sc/main.scd"

# 既存プロセスを停止
pkill jackd 2>/dev/null || true
pkill sclang 2>/dev/null || true
sleep 1

# HDMI出力で JACK を起動する設定
# ~/.jackdrc は scsynth が jackd を自動起動する際に読む (フルパス必須)
JACKD=$(command -v jackd)
# plughw:1 = ALSA plugin layer が IEC958 フォーマット変換を行う
echo "$JACKD -d alsa -d plughw:1 -r 44100 -p 1024 -n 2" > ~/.jackdrc

export QT_QPA_PLATFORM=offscreen

echo "[lattice] Starting SuperCollider (HDMI via JACK hw:1)..."

# PulseAudio がデバイスを占有している場合、pasuspender で一時解放
if command -v pasuspender &>/dev/null && pulseaudio --check 2>/dev/null; then
    exec pasuspender -- sclang "$SC_MAIN"
else
    exec sclang "$SC_MAIN"
fi
